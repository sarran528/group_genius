# ===============================
# DATABASE CONFIGURATION (Aiven MySQL)
# ===============================
# Replace these dummy values with your actual Aiven MySQL credentials
DATABASE_URL=jdbc:mysql://your-aiven-host.aivencloud.com:12345/defaultdb?sslmode=require
DATABASE_USERNAME=avnadmin
DATABASE_PASSWORD=your-aiven-password-here

# ===============================
# EMAIL CONFIGURATION
# ===============================
# Email service toggle (set to true to enable real email sending)
EMAIL_ENABLED=false

# Frontend URL for email links and CORS
# Example: https://app.your-frontend.com
FRONTEND_URL=https://group-genius.vercel.app

# Allow localhost origins (set to false in production deployments)
APP_ALLOW_DEV_ORIGINS=true

# Comma-separated localhost origins used only for development
APP_DEV_ORIGINS=http://localhost:5173,http://localhost:8080

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here

# ===============================
# LOGGING CONFIGURATION
# ===============================
# Optional: Customize log pattern
# LOGPATTERN_CONSOLE=%green(%d{HH:mm:ss.SSS}) %blue(%-5level) %red([%thread]) %yellow(%logger{15}) - %msg%n
